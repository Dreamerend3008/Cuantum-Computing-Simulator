---
import Layout from '../layouts/Layout.astro';
import { Content as DocsContent } from '../../DOCUMENTATION.md';
---

<Layout title="Documentación | Kuantum">
    <div class="docs-wrapper">
        <div class="docs-container">
            <DocsContent />
        </div>
    </div>
</Layout>

<style is:global>
    .docs-wrapper {
        padding: 2rem 0;
    }

    .docs-container {
        max-width: 900px;
        margin: 0 auto;
        background: #ffffff;
        padding: 3rem 4rem;
        border-radius: 16px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.05);
        color: var(--text-main);
    }

    .docs-container h1 {
        color: var(--primary-blue);
        font-size: 2.8rem;
        margin-bottom: 1.5rem;
        letter-spacing: -0.02em;
    }

    .docs-container h2 {
        color: var(--accent-pink);
        font-size: 1.8rem;
        margin-top: 3rem;
        margin-bottom: 1rem;
        border-bottom: 2px solid rgba(233, 56, 176, 0.1);
        padding-bottom: 0.5rem;
    }

    .docs-container h3 {
        color: var(--text-main);
        font-size: 1.4rem;
        margin-top: 2rem;
        margin-bottom: 1rem;
    }

    .docs-container p {
        line-height: 1.7;
        margin-bottom: 1.5rem;
        font-size: 1.05rem;
    }

    .docs-container ul, .docs-container ol {
        padding-left: 1.5rem;
        margin-bottom: 2rem;
        line-height: 1.7;
        font-size: 1.05rem;
    }

    .docs-container li {
        margin-bottom: 0.5rem;
    }

    .docs-container pre {
        background: #1A1A1D;
        color: var(--accent-green);
        padding: 1.25rem;
        border-radius: 8px;
        overflow-x: auto;
        margin-bottom: 1.5rem;
        font-family: monospace;
        font-size: 0.95rem;
        box-shadow: inset 0 2px 10px rgba(0,0,0,0.5);
    }

    .docs-container code {
        font-family: monospace;
        background: rgba(0, 0, 0, 0.05);
        padding: 0.2rem 0.4rem;
        border-radius: 4px;
        font-size: 0.9em;
        color: var(--accent-pink);
    }

    .docs-container pre code {
        background: transparent;
        padding: 0;
        color: inherit;
    }

    .docs-container table {
        width: 100%;
        border-collapse: collapse;
        margin: 2rem 0;
        font-size: 0.95rem;
    }

    .docs-container th, .docs-container td {
        border: 1px solid rgba(0, 0, 0, 0.08);
        padding: 1rem;
        text-align: left;
    }

    .docs-container th {
        background: #FAFAFA;
        font-weight: 700;
        color: var(--primary-blue);
    }

    .docs-container tr:nth-child(even) {
        background: rgba(0, 0, 0, 0.02);
    }

    .docs-container a {
        color: var(--primary-blue);
        text-decoration: none;
        font-weight: 600;
        transition: color 0.2s ease;
    }

    .docs-container a:hover {
        color: var(--accent-pink);
        text-decoration: underline;
    }

    .docs-container hr {
        border: 0;
        height: 1px;
        background: rgba(0, 0, 0, 0.1);
        margin: 3rem 0;
    }

    @media (max-width: 768px) {
        .docs-container {
            padding: 2rem 1.5rem;
        }
        .docs-container h1 {
            font-size: 2.2rem;
        }
    }
</style>
