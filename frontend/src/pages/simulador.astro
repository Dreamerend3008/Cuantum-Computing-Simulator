---
import Layout from '../layouts/Layout.astro';
const apiBase = import.meta.env.PUBLIC_API_BASE_URL;
---

<Layout title="Simulador">
  <div class="simulator-container">
    <h1>Simulador de Circuitos Cuánticos</h1>

    <div class="form-group">
      <label for="num_qubits">Número de qubits</label>
      <input type="number" id="num_qubits" min="1" value="2" />
    </div>

    <div class="form-group">
      <label for="initial_state">Estado inicial</label>
      <input type="text" id="initial_state" placeholder="ej: 00" value="00" />
    </div>

    <div class="form-group">
      <label for="runner_mode">Modo</label>
      <select id="runner_mode">
        <option value="shot">Shot</option>
        <option value="statevector">Statevector</option>
      </select>
    </div>

    <div class="form-group" id="shots-group">
      <label for="shots">Shots</label>
      <input type="number" id="shots" min="1" value="1024" />
    </div>

    <div class="form-group">
      <label for="num_clbits">Número de clbits</label>
      <input type="number" id="num_clbits" min="0" value="2" />
    </div>

    <div class="form-group">
      <label for="noise_model">Modelo de ruido</label>
      <select id="noise_model">
        <option value="">Ninguno</option>
        <option value="depolarizing">Depolarizing</option>
        <option value="thermal_relaxation">Thermal Relaxation</option>
      </select>
    </div>

    <div class="form-group">
    <label>Instrucciones (puertas)</label>
    <div id="instructions-list"></div>

    <button id="add-gate">+ Agregar puerta</button>

    <div id="gate-panel" style="display:none">
        <select id="gate-select">
        <option>H</option><option>X</option><option>Y</option>
        <option>Z</option><option>S</option><option>T</option>
        <option>RX</option><option>RY</option><option>RZ</option>
        <option>CX</option><option>SWAP</option><option>CXX</option>
        <option>HALF_ADD</option><option>FULL_ADD</option>
        <option>OLD_FULL_ADD</option><option>QFT</option>
        <option>IQFT</option><option>INITIALIZE</option>
        </select>

        <div id="qubit-inputs"></div>

        <input type="number" id="param-value" placeholder="Parámetro (ej: 1.5708)" step="0.0001" style="display:none" />
        <div id="param-input" style="display:none">
        <label>Parámetro</label>
        </div>

        <button id="confirm-gate">✓ Agregar</button>
    </div>
    </div>

    <button id="run-btn">Ejecutar simulación</button>

    <div id="result"></div>
  </div>
</Layout>

<script define:vars={{ apiBase }}>

  // ============================================================
  // [IA] Lógica de puertas dinámicas
  // ============================================================
  const GATES = {
    "H":            { qubits: 1, params: false },
    "X":            { qubits: 1, params: false },
    "Y":            { qubits: 1, params: false },
    "Z":            { qubits: 1, params: false },
    "S":            { qubits: 1, params: false },
    "T":            { qubits: 1, params: false },
    "RX":           { qubits: 1, params: true  },
    "RY":           { qubits: 1, params: true  },
    "RZ":           { qubits: 1, params: true  },
    "CX":           { qubits: 2, params: false },
    "SWAP":         { qubits: 2, params: false },
    "CXX":          { qubits: 3, params: false },
    "HALF_ADD":     { qubits: 4, params: false },
    "FULL_ADD":     { qubits: 4, params: false },
    "OLD_FULL_ADD": { qubits: 4, params: false },
    "QFT":          { qubits: null, params: false },
    "IQFT":         { qubits: null, params: false },
    "INITIALIZE":   { qubits: null, params: true  },
  }

  let instructions = []

  const addGateBtn       = document.getElementById("add-gate")
  const gatePanel        = document.getElementById("gate-panel")
  const gateSelect       = document.getElementById("gate-select")
  const qubitInputs      = document.getElementById("qubit-inputs")
  const paramInput       = document.getElementById("param-input")
  const confirmGate      = document.getElementById("confirm-gate")
  const instructionsList = document.getElementById("instructions-list")

  addGateBtn.addEventListener('click', () => {
    gatePanel.style.display = gatePanel.style.display === "none" ? "block" : "none"
  })

  gateSelect.addEventListener('change', () => {
    const gate = GATES[gateSelect.value]

    qubitInputs.innerHTML = ""
    if (gate.qubits !== null) {
      for (let i = 0; i < gate.qubits; i++) {
        const input = document.createElement("input")
        input.type = "number"
        input.min = "1"
        input.placeholder = `Qubit ${i + 1}`
        input.className = "qubit-input"
        qubitInputs.appendChild(input)
      }
    }

    paramInput.style.display = gate.params ? "block" : "none"
  })

  gateSelect.dispatchEvent(new Event('change'))

  confirmGate.addEventListener('click', () => {
    const gateName = gateSelect.value
    const gate = GATES[gateName]

    let qubits = []
    if (gate.qubits !== null) {
      const inputs = qubitInputs.querySelectorAll(".qubit-input")
      qubits = Array.from(inputs).map(inp => parseInt(inp.value))
    }

    const paramValue = document.getElementById("param-value")
    let params = undefined
    if (gate.params && paramValue.value !== "") {
      params = [parseFloat(paramValue.value)]
    }

    const instruction = { name: gateName, qubits }
    if (params !== undefined) instruction.params = params

    instructions.push(instruction)
    renderInstructions()
    gatePanel.style.display = "none"
  })

  function renderInstructions() {
    instructionsList.innerHTML = ""
    instructions.forEach((inst, index) => {
      const div = document.createElement("div")
      div.className = "instruction-item"
      div.innerHTML = `
        <span>${inst.name} — qubits: [${inst.qubits.map(q => q + 1).join(", ")}]${inst.params ? " — params: " + inst.params : ""}</span>
        <button class="remove-btn">✕</button>
      `
      div.querySelector(".remove-btn").addEventListener('click', () => {
        instructions.splice(index, 1)
        renderInstructions()
      })
      instructionsList.appendChild(div)
    })
  }

  // ============================================================
  // [/IA]
  // ============================================================


  // Tu código original
  const button = document.getElementById("run-btn")
  button.addEventListener('click', async function() {
    const num_qubits    = document.getElementById("num_qubits").value
    const num_clbits    = document.getElementById("num_clbits").value
    const runner_mode   = document.getElementById("runner_mode").value
    const noise_model   = document.getElementById("noise_model").value || null
    const shots         = document.getElementById("shots").value

    const payload = {
      num_qubits:    parseInt(num_qubits),
      num_clbits:    parseInt(num_clbits),
      initial_state: document.getElementById("initial_state").value,
      instructions:  instructions, 
      runner_mode:   runner_mode,
      noise_model:   noise_model,
      shots:         parseInt(shots)
    }

    const response = await fetch(`${apiBase}/simulations/run`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(payload)
    })

    const retorno = await response.json()
    document.getElementById("result").innerHTML =
      `
        Estado: ${retorno.status} \n
        Probabilidades: ${JSON.stringify(retorno.data.probabilities)}
    `
  })

</script>