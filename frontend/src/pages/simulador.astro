---
import Layout from '../layouts/Layout.astro';
import CircuitGrid from '../components/simulator/CircuitGrid.astro';
import QuantumResults from '../components/simulator/QuantumResults.astro';
import BlochSphere from '../components/simulator/BlochSphere.astro';
const apiBase = import.meta.env.PUBLIC_API_BASE_URL;
---

<Layout title="Simulador">
  <div class="simulator-wrapper">
    <header class="sim-header">
      <h1>Dashboard de Simulación Cuántica</h1>
      <p>Configura tu circuito, agrega compuertas lógicas y ejecuta la simulación en tiempo real.</p>
    </header>

    <div class="sim-grid-top">
      <!-- PANEL IZQUIERDO: CONFIGURACIÓN -->
      <aside class="panel config-panel">
        <h2>Configuración</h2>
        <div class="form-grid">
            <div class="form-group">
                <label for="num_qubits">Qubits</label>
                <input type="number" id="num_qubits" min="1" value="2" />
            </div>
            <div class="form-group">
                <label for="num_clbits">Clbits</label>
                <input type="number" id="num_clbits" min="0" value="0" />
            </div>
            <div class="form-group full-width">
                <label for="initial_state">Estado inicial</label>
                <input type="text" id="initial_state" placeholder="ej: 00" value="00" />
            </div>
            <div class="form-group">
                <label for="runner_mode">Modo</label>
                <select id="runner_mode">
                    <option value="shot">Shot</option>
                    <option value="statevector">Statevector</option>
                </select>
            </div>
            <div class="form-group" id="shots-group">
                <label for="shots">Shots</label>
                <input type="number" id="shots" min="1" value="1024" />
            </div>
            <div class="form-group full-width">
                <label for="noise_model">Modelo de ruido</label>
                <select id="noise_model">
                    <option value="">Ninguno</option>
                    <option value="depolarizing">Depolarizing</option>
                    <option value="thermal_relaxation">Thermal Rel.</option>
                </select>
            </div>
        </div>
        
        <!-- Parámetros de Compuerta Seleccionada -->
        <div id="gate-params-container" class="gate-form-panel" style="display: none; margin-top: 1.5rem; border-color: var(--accent-purple);">
            <h3 style="margin-top:0; font-size: 1rem; color: var(--accent-purple);">Parámetros: <span id="selected-gate-name"></span></h3>
            <div class="form-group" id="params-inputs-container">
                <!-- Generados via JS -->
            </div>
            <p style="font-size: 0.75rem; color: var(--koala-grey); margin-top: 0.5rem; margin-bottom: 0;">Presiona Enter o haz clic fuera para aplicar.</p>
        </div>

        <!-- Guardar Compuerta Personalizada -->
        <div class="gate-form-panel" style="margin-top: 1.5rem; border-color: var(--primary-blue);">
            <h3 style="margin-top:0; font-size: 1rem; color: var(--primary-blue);">Crear Compuerta</h3>
            <p style="font-size: 0.8rem; color: var(--koala-grey); margin-bottom: 0.5rem; margin-top: 0;">Guarda el circuito actual como un bloque reutilizable.</p>
            <div class="form-group">
                <input type="text" id="custom_gate_name" placeholder="Nombre (ej: MY_BELL)" />
            </div>
            <button id="save-custom-gate-btn" class="btn btn-outline" style="width: 100%; margin-top: 0.5rem;">Guardar Circuito Actual</button>
        </div>

        <div class="execute-section" style="margin-top: 2rem;">
            <button id="run-btn" class="btn btn-primary btn-massive">Ejecutar Simulación</button>
        </div>
      </aside>

      <!-- PANEL DERECHO: CIRCUITO -->
      <main class="panel circuit-panel" style="padding: 0; background: transparent; box-shadow: none; border: none;">
        <CircuitGrid />
      </main>
    </div>

    <!-- SECCIÓN INFERIOR: RESULTADOS -->
    <div class="sim-bottom-section">
        <div class="results-container panel">
            <h2>Visualizador de Resultados</h2>
            <QuantumResults />
        </div>

        <BlochSphere />
    </div>
  </div>
</Layout>

<style>
.simulator-wrapper {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 2rem;
}

.sim-header h1 {
    font-size: 2.2rem;
    margin-bottom: 0.5rem;
    color: var(--text-main);
}
.sim-header p {
    color: var(--koala-grey);
    font-size: 1.05rem;
    margin: 0;
}

.sim-grid-top {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 1.5rem;
    align-items: start;
}

.sim-bottom-section {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    margin-top: 1rem;
}

@media (max-width: 1024px) {
    .sim-grid-top {
        grid-template-columns: 1fr;
    }
}

.panel {
    background: #ffffff;
    border-radius: 12px;
    padding: 1.5rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
    border: 1px solid rgba(0,0,0,0.05);
}

.panel h2 {
    font-size: 1.25rem;
    margin-top: 0;
    margin-bottom: 1.5rem;
    color: var(--primary-blue);
    border-bottom: 2px solid rgba(37, 150, 190, 0.1);
    padding-bottom: 0.5rem;
}

.form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
}
.form-grid .full-width {
    grid-column: 1 / -1;
}

.form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
}
.flex-grow {
    flex: 1;
}

label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-main);
}

input, select {
    width: 100%;
    box-sizing: border-box;
    padding: 0.6rem 0.75rem;
    border: 1px solid color-mix(in srgb, var(--koala-grey) 40%, transparent);
    border-radius: 6px;
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem;
    color: var(--text-main);
    background: #FAFAFA;
    transition: all 0.2s ease;
}

input:focus, select:focus {
    outline: none;
    border-color: var(--primary-blue);
    box-shadow: 0 0 0 3px rgba(37, 150, 190, 0.15);
    background: #ffffff;
}

/* Central Panel */
.panel-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
}
.panel-header h2 {
    margin: 0;
    border: none;
    padding: 0;
}

.btn {
    padding: 0.6rem 1.2rem;
    border-radius: 8px;
    font-weight: 600;
    cursor: pointer;
    font-family: 'Inter', sans-serif;
    transition: all 0.2s ease;
    border: none;
    font-size: 0.95rem;
}

.btn-outline {
    background: transparent;
    color: var(--primary-blue);
    border: 1px solid var(--primary-blue);
}
.btn-outline:hover {
    background: rgba(37, 150, 190, 0.1);
}

.btn-secondary {
    background: var(--primary-blue);
    color: #fff;
}
.btn-secondary:hover {
    background: #1e7a9b; /* Slightly darker */
}

.gate-form-panel {
    background: var(--bg-color);
    border-radius: 8px;
    padding: 1.25rem;
    margin-bottom: 1.5rem;
    border: 1px dashed var(--koala-grey);
}
.gate-form-row {
    display: flex;
    gap: 1rem;
    margin-bottom: 1rem;
    align-items: flex-end;
}
.qubit-inputs-row {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
}
.qubit-inputs-row input {
    width: 80px;
}
#confirm-gate {
    margin-top: 1rem;
    width: 100%;
}

.instructions-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    min-height: 200px;
}

.empty-state {
    text-align: center;
    padding: 3rem 1rem;
    color: var(--koala-grey);
    border: 2px dashed rgba(0,0,0,0.1);
    border-radius: 8px;
    font-size: 0.95rem;
}

/* Modificamos cómo se ven las instrucciones desde JS */
:global(.instruction-item) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: white;
    padding: 0.75rem 1rem;
    border-radius: 8px;
    border-left: 4px solid var(--accent-purple);
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem;
    color: var(--text-main);
    transition: transform 0.2s ease;
}
:global(.instruction-item:hover) {
    transform: translateX(4px);
}
:global(.instruction-item button) {
    background: transparent;
    border: none;
    color: var(--koala-grey);
    cursor: pointer;
    font-size: 1.2rem;
    transition: color 0.2s;
    padding: 0 0.5rem;
}
:global(.instruction-item button:hover) {
    color: var(--accent-pink); /* Use the pink for destructive/remove */
}
:global(.instruction-gate-name) {
    font-weight: 700;
    color: var(--primary-blue);
    margin-right: 0.5rem;
}
:global(.instruction-details) {
    color: var(--koala-grey);
    font-size: 0.85rem;
}

/* Right Panel */
.btn-primary {
    background: var(--accent-pink);
    color: white;
}
.btn-massive {
    width: 100%;
    padding: 1rem;
    font-size: 1.1rem;
    box-shadow: 0 4px 15px rgba(233, 56, 176, 0.3);
}
.btn-massive:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(233, 56, 176, 0.4);
}

.results-container {
    margin-top: 2rem;
}
.results-container h3 {
    font-size: 1.1rem;
    color: var(--text-main);
    margin-bottom: 1rem;
    border-bottom: 2px solid rgba(0,0,0,0.05);
    padding-bottom: 0.5rem;
}
.console-output {
    background: #1A1A1D; /* Dark terminal look */
    color: var(--accent-green); /* Green text */
    padding: 1rem;
    border-radius: 8px;
    font-family: monospace;
    font-size: 0.85rem;
    min-height: 150px;
    max-height: 400px;
    overflow-y: auto;
    white-space: pre-wrap;
    word-break: break-all;
    box-shadow: inset 0 2px 10px rgba(0,0,0,0.5);
    line-height: 1.5;
}
</style>

<script define:vars={{ apiBase }}>
  window.apiBase = apiBase;

  window.addEventListener('DOMContentLoaded', () => {
      if (window.loadCustomGates) {
          window.loadCustomGates();
      }
  });

  window.onGateSelected = (gate, idx) => {
      const container = document.getElementById('gate-params-container');
      const nameEl = document.getElementById('selected-gate-name');
      const inputsContainer = document.getElementById('params-inputs-container');
      
      const scalableGates = ['QFT', 'IQFT', 'MOD_EXP', 'CXX', 'HALF_ADD', 'FULL_ADD', 'OLD_FULL_ADD'];
      const hasParams = gate && (gate.params !== undefined || scalableGates.includes(gate.type) || (gate.span && gate.span > 1));
      
      if (!gate || !hasParams) {
          container.style.display = 'none';
          return;
      }
      
      container.style.display = 'block';
      nameEl.innerText = gate.type;
      inputsContainer.innerHTML = '';

      
      if (gate.type === 'INITIALIZE') {
          const wrapper = document.createElement('div');
          wrapper.style.display = 'flex';
          wrapper.style.flexDirection = 'column';
          wrapper.style.gap = '0.2rem';
          wrapper.style.marginBottom = '0.8rem';

          const label = document.createElement('label');
          label.style.fontSize = '0.8rem';
          label.style.color = 'var(--koala-grey)';
          let input;
          if (gate.type === 'INITIALIZE') {
              input = document.createElement('textarea');
              label.innerText = 'Amplitudes (α, β, ...)';
              input.placeholder = 'ej: 0.707, 0.707\nPara 2 qubits:\n0.5, 0.5, 0.5, 0.5';
          }
          input.style.resize = 'vertical';
          input.style.minHeight = '60px';
          input.style.fontFamily = 'monospace';
          // Para INITIALIZE, gate.params es el arreglo plano de amplitudes [1, 0]
          input.value = gate.params.join(', ');
          
          input.addEventListener('input', function() {
              this.style.height = 'auto';
              this.style.height = (this.scrollHeight + 2) + 'px';
          });
          setTimeout(() => input.dispatchEvent(new Event('input')), 10);

          input.addEventListener('change', (e) => {
              let val = e.target.value;
              let reqSpan = 1;
              let valArr;
              
              if (!val.trim()) {
                  valArr = [1, 0];
              } else {
                  valArr = val.split(',').map(v => parseFloat(v.trim()) || 0);
                  reqSpan = Math.log2(valArr.length);
                  if (!Number.isInteger(reqSpan) || reqSpan < 1) {
                      reqSpan = Math.max(1, Math.ceil(reqSpan));
                      let dim = Math.pow(2, reqSpan);
                      while (valArr.length < dim) valArr.push(0);
                  }
              }
              
              if (window.updateSelectedGateParams) {
                  window.updateSelectedGateParams(valArr, reqSpan);
              }
          });

          wrapper.appendChild(label);
          wrapper.appendChild(input);
          inputsContainer.appendChild(wrapper);

      } else {
          // Mostrar campo de qubits para compuertas escalables o multi-qubit
          const hasSpanControl = scalableGates.includes(gate.type) || (gate.span && gate.span > 1);
          if (hasSpanControl) {
              const wrapper = document.createElement('div');
              wrapper.style.display = 'flex';
              wrapper.style.flexDirection = 'column';
              wrapper.style.gap = '0.2rem';
              wrapper.style.marginBottom = '0.8rem';
              
              const label = document.createElement('label');
              label.style.fontSize = '0.8rem';
              label.style.color = 'var(--koala-grey)';
              label.innerText = 'Cantidad de Qubits';

              const input = document.createElement('input');
              input.type = 'number';
              input.min = gate.type === 'MOD_EXP' ? 5 : (gate.span || 1);
              const maxSpan = window.circuitData.qubits - gate.target;
              input.max = maxSpan;
              input.value = gate.span || 1;

              input.addEventListener('change', (e) => {
                  let newSpan = parseInt(e.target.value) || parseInt(input.min);
                  if (newSpan < parseInt(input.min)) newSpan = parseInt(input.min);
                  if (newSpan > maxSpan) newSpan = maxSpan;
                  input.value = newSpan;
                  
                  if (window.updateSelectedGateParams) {
                      window.updateSelectedGateParams(gate.params, newSpan);
                  }
              });

              wrapper.appendChild(label);
              wrapper.appendChild(input);
              inputsContainer.appendChild(wrapper);
          }

          // Add input for each param
          if (gate.params) {
              gate.params.forEach((param, pIdx) => {
                  const wrapper = document.createElement('div');
              wrapper.style.display = 'flex';
              wrapper.style.flexDirection = 'column';
              wrapper.style.gap = '0.2rem';
              wrapper.style.marginBottom = '0.8rem';

              const label = document.createElement('label');
              label.style.fontSize = '0.8rem';
              label.style.color = 'var(--koala-grey)';
              if (gate.type === 'MOD_EXP') {
                  label.innerText = pIdx === 0 ? 'Base "a" (ej: 7)' : 'Módulo "N" (fijo 15)';
              } else {
                  label.innerText = 'Ángulo de rotación θ (rad)';
              }
              
              const input = document.createElement('input');
              input.type = 'number';
              input.step = 'any';
              if (gate.type === 'MOD_EXP') {
                  input.placeholder = pIdx === 0 ? '7' : '15';
              } else {
                  input.placeholder = 'ej: 3.1415';
              }
              input.value = param;
              
              input.addEventListener('change', (e) => {
                  let val = parseFloat(e.target.value) || 0;
                  const newParams = [...gate.params];
                  newParams[pIdx] = val;
                  if (window.updateSelectedGateParams) {
                      window.updateSelectedGateParams(newParams, null);
                  }
              });
              
              wrapper.appendChild(label);
              wrapper.appendChild(input);
              inputsContainer.appendChild(wrapper);
          });
          }
      }
  };

  document.getElementById("save-custom-gate-btn").addEventListener('click', async () => {
      const name = document.getElementById("custom_gate_name").value.trim().toUpperCase().replace(/\s+/g, '_');
      if (!name) return alert("Por favor ingresa un nombre para la compuerta.");
      
      const instructions = window.getLegacyInstructions ? window.getLegacyInstructions() : [];
      if (instructions.length === 0) return alert("El circuito está vacío.");
      
      let maxQubit = 0;
      instructions.forEach(inst => {
          inst.qubits.forEach(q => {
              if (q > maxQubit) maxQubit = q;
          });
      });
      
      const payload = {
          name: name,
          num_qubits: maxQubit + 1,
          instructions: instructions
      };
      
      try {
          const response = await fetch(`${apiBase}/circuits/custom-gates`, {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify(payload)
          });
          if (response.ok) {
              alert(`Compuerta ${name} guardada con éxito.`);
              if (window.loadCustomGates) window.loadCustomGates();
              document.getElementById("custom_gate_name").value = "";
          } else {
              const err = await response.json();
              alert("Error al guardar: " + JSON.stringify(err));
          }
      } catch (e) {
          alert("Error de conexión: " + e.message);
      }
  });

  // Sincronizar qubits con la grilla
  document.getElementById("num_qubits").addEventListener("change", (e) => {
      const num = parseInt(e.target.value);
      if (num > 0 && window.setCircuitQubits) {
          window.setCircuitQubits(num);
      }
  });

  const button = document.getElementById("run-btn")
  button.addEventListener('click', async function() {
    const num_qubits    = document.getElementById("num_qubits").value
    const num_clbits    = document.getElementById("num_clbits").value
    const runner_mode   = document.getElementById("runner_mode").value
    const noise_model   = document.getElementById("noise_model").value || null
    const shots         = document.getElementById("shots").value

    // Obtenemos las instrucciones mapeadas al formato viejo desde CircuitGrid
    const instructions = window.getLegacyInstructions ? window.getLegacyInstructions() : [];

    const payload = {
      num_qubits:    parseInt(num_qubits),
      num_clbits:    parseInt(num_clbits),
      initial_state: document.getElementById("initial_state").value,
      instructions:  instructions, 
      runner_mode:   runner_mode,
      noise_model:   noise_model,
      shots:         parseInt(shots)
    }

    const response = await fetch(`${apiBase}/simulations/run`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(payload)
    });

    if (!response.ok) {
        let errMsg = "Error desconocido";
        try {
            const err = await response.json();
            errMsg = err.detail || err.error || JSON.stringify(err);
        } catch(e) {}
        alert("Error en la simulación:\n\n" + errMsg);
        return;
    }

    const retorno = await response.json();
    
    // Attach last gate info for Bloch sphere animation
    if (retorno.data && instructions.length > 0) {
        const lastGate = instructions[instructions.length - 1];
        retorno.data._lastGateInfo = {
            type: lastGate.name,
            qubit: lastGate.qubits ? lastGate.qubits[lastGate.qubits.length - 1] : 0
        };
    }

    // Llamar a la función del componente QuantumResults para renderizar
    if (window.renderQuantumResults) {
        window.renderQuantumResults(retorno.data);
    }
  })

</script>