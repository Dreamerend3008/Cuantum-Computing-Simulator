---
import Layout from '../../layouts/Layout.astro';
import ConceptCard from '../../components/theory/ConceptCard.astro';
import { getCollection } from 'astro:content';

const lessons = (await getCollection('theory')).sort((a, b) => a.data.order - b.data.order);
---

<Layout title="Aprender — Kuantum">
	<header class="page-header">
		<h1>Aprender</h1>
		<p class="lead">
			Conceptos de computación cuántica para Kuantum. Sigue las lecciones en orden o entra en la que te interese; al final puedes practicar en el simulador.
		</p>
	</header>

	<section class="section">
		<h2 class="section-title">Lecciones</h2>
		<div class="grid">
			{
				lessons.map((entry) => (
					<ConceptCard
						title={entry.data.title}
						description={entry.data.description}
						href={`/teoria/${entry.id}/`}
					/>
				))
			}
		</div>
	</section>
</Layout>

<style>
	.page-header {
		margin-bottom: 2.5rem;
	}

	.page-header h1 {
		margin: 0 0 0.75rem;
		font-size: clamp(1.75rem, 4vw, 2.5rem);
	}

	.lead {
		margin: 0;
		line-height: 1.6;
		color: var(--koala-grey);
		font-size: 1.05rem;
	}

	.section {
		margin-bottom: 2.5rem;
	}

	.section-title {
		margin: 0 0 1rem;
		font-size: 1.1rem;
		font-weight: 600;
		color: var(--text-main);
		text-transform: uppercase;
		letter-spacing: 0.04em;
	}

	.grid {
		display: grid;
		gap: 1rem;
		grid-template-columns: 1fr;
	}

	@media (min-width: 640px) {
		.grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	.footer-cta {
		margin-top: 2rem;
		padding-top: 1.5rem;
		border-top: 1px solid color-mix(in srgb, var(--koala-grey) 30%, transparent);
		color: var(--koala-grey);
	}

	.footer-cta a {
		font-weight: 600;
		color: var(--accent-purple);
		margin-left: 0.35rem;
	}
</style>
