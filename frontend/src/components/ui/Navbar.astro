---
---

<nav class="navbar global-nav-footer">
    <div class="nav-left">
        <img src="/logo.png" alt="Logo Kuantum" class="navbar-logo" />
        <a href="/" class="title">KUANTUM</a>
    </div>

    <div class="nav-center">
        <a href="/simulador/" class="nav-link">Simulador</a>
        <a href="/teoria/" class="nav-link">Teoría</a>
        <a href="/docs/" class="nav-link">Documentación</a>
    </div>

    <div class="nav-right">
        <button id="theme-toggle" class="theme-toggle" aria-label="Alternar modo de tema">
            🌙
        </button>
    </div>
</nav>

<style>
    .navbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem 2rem;
    }

    .nav-left {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .navbar-logo {
        width: 75px; 
        height: auto;  
        object-fit: contain;
    }

    .title {
        font-family: 'Quicksand', sans-serif;
        font-size: 1.75rem;
        font-weight: 700;
        text-decoration: none;
        letter-spacing: 1px;
    }

    .title:hover {
        color: var(--secondary-cyan);
    }

    .nav-center {
        display: flex;
        gap: 2rem;
    }

    .nav-link {
        font-weight: 500;
        text-decoration: none;
        transition: color 0.2s;
    }

    .nav-link:hover {
        color: var(--secondary-cyan);
    }

    .nav-right {
        display: flex;
        align-items: center;
    }

    .theme-toggle {
        background: transparent;
        border: 2px solid transparent;
        color: var(--text-main);
        font-size: 1.25rem;
        cursor: pointer;
        padding: 0.5rem;
        border-radius: 8px;
        transition: all 0.3s ease;
    }

    .theme-toggle:hover {
        color: var(--secondary-cyan);
        background: rgba(0, 229, 255, 0.1); /* Efecto hover suave usando el color Cian */
    }
</style>

<script>
    const handleToggleClick = () => {
        const element = document.documentElement;
        element.classList.toggle("dark");
        
        const isDark = element.classList.contains("dark");
        localStorage.setItem("theme", isDark ? "dark" : "light");

        const btn = document.getElementById("theme-toggle");
        if (btn) {
            btn.textContent = isDark ? "☀️" : "🌙";
        }
    };

    document.getElementById("theme-toggle")?.addEventListener("click", handleToggleClick);

    // Initial setup
    const isDark = document.documentElement.classList.contains("dark");
    const btn = document.getElementById("theme-toggle");
    if (btn) {
        btn.textContent = isDark ? "☀️" : "🌙";
    }
</script>