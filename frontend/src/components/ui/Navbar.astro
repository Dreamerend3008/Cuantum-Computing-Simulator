---

<nav class="navbar global-nav-footer">
    <div class="nav-left">
        <img src="/logo.png" alt="Logo Kuantum" class="navbar-logo" />
        <a href="/" class="title">KUANTUM</a>
    </div>

    <div class="nav-center">
        <a href="/simulador/" class="nav-link">Simulador</a>
        <a href="/teoria/" class="nav-link">Teoría</a>
        <a href="/docs/" class="nav-link">Documentación</a>
    </div>
</nav>

<style>
    .navbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem 2.5rem;
        /* Gradiente vibrante y elegante */
        background: linear-gradient(135deg, var(--accent-purple) 0%, var(--accent-pink) 100%);
        box-shadow: 0 4px 20px rgba(233, 56, 176, 0.2);
        position: sticky;
        top: 0;
        z-index: 1000;
        color: #FFFFFF;
    }

    .nav-left {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .navbar-logo {
        width: 45px; 
        height: auto;  
        object-fit: contain;
        transition: transform 0.3s ease;
        /* Hacemos que el logo resalte sobre el fondo oscuro (si aplica) */
        filter: drop-shadow(0px 2px 4px rgba(0,0,0,0.2));
    }

    .navbar-logo:hover {
        transform: scale(1.05) rotate(-5deg);
    }

    .title {
        font-family: 'Quicksand', sans-serif;
        font-size: 1.5rem;
        font-weight: 800;
        text-decoration: none;
        letter-spacing: -0.02em;
        color: #FFFFFF;
        transition: opacity 0.3s ease;
    }

    .title:hover {
        opacity: 0.9;
    }

    .nav-center {
        display: flex;
        gap: 2.5rem;
    }

    .nav-link {
        font-weight: 600;
        font-size: 1rem;
        text-decoration: none;
        color: rgba(255, 255, 255, 0.85);
        position: relative;
        padding: 0.5rem 0;
        transition: color 0.3s ease;
    }

    .nav-link::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        width: 0%;
        height: 2px;
        background-color: #FFFFFF;
        transition: width 0.3s ease;
        border-radius: 2px;
    }

    .nav-link:hover {
        color: #FFFFFF;
    }

    .nav-link:hover::after {
        width: 100%;
    }

    @media (max-width: 768px) {
        .navbar {
            padding: 1rem;
            flex-direction: column;
            gap: 1rem;
        }
        .nav-center {
            gap: 1.5rem;
        }
    }
</style>