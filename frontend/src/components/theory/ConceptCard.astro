---
interface Props {
	title: string;
	description: string;
	href?: string;
	comingSoon?: boolean;
}

const { title, description, href, comingSoon = false } = Astro.props;
---

<article class:list={['card', { 'card--soon': comingSoon }]}>
	<h2 class="card-title">{title}</h2>
	<p class="card-desc">{description}</p>
	{
		comingSoon ? (
			<span class="card-badge">Próximamente</span>
		) : (
			<a href={href} class="card-link">
				Leer lección →
			</a>
		)
	}
</article>

<style>
	.card {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		padding: 1.25rem 1.5rem;
		border-radius: 12px;
		background: color-mix(in srgb, var(--bg-color) 92%, var(--primary-blue));
		border: 1px solid color-mix(in srgb, var(--koala-grey) 35%, transparent);
		transition: box-shadow 0.2s ease, transform 0.2s ease;
	}

	.card:not(.card--soon):hover {
		box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
		transform: translateY(-2px);
	}

	.card--soon {
		opacity: 0.85;
	}

	.card-title {
		margin: 0;
		font-size: 1.25rem;
		color: var(--text-main);
	}

	.card-desc {
		margin: 0;
		flex: 1;
		line-height: 1.5;
		color: var(--koala-grey);
		font-size: 0.95rem;
	}

	.card-link {
		font-weight: 600;
		color: var(--accent-pink);
		text-decoration: none;
	}

	.card-link:hover {
		text-decoration: underline;
	}

	.card-badge {
		align-self: flex-start;
		font-size: 0.8rem;
		font-weight: 600;
		padding: 0.25rem 0.65rem;
		border-radius: 999px;
		background: color-mix(in srgb, var(--koala-grey) 25%, transparent);
		color: var(--text-main);
	}
</style>
