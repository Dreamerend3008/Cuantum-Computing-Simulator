---
import Navbar from '../components/ui/Navbar.astro';
import Footer from '../components/ui/Footer.astro';

interface Props {
	title: string;
	showNavAndFooter?: boolean;
}

const { title, showNavAndFooter = true } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Kuantum - Simulador de Circuitos Cuánticos" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
        
        <!-- Google Fonts -->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Quicksand:wght@500;700&display=swap" rel="stylesheet">
		
        <title>{title}</title>

	</head>
	<body>
        <div class="app-container">
            {showNavAndFooter && <Navbar />}
            <main class={!showNavAndFooter ? "no-padding" : ""}>
                <slot />
            </main>
            {showNavAndFooter && <Footer />}
        </div>
	</body>
</html>

<style is:global>
	:root {
		/* Paleta de colores estandarizada */
		--bg-color: #F0F1F1;
		--text-main: #2C3E50;
		--koala-grey: #808e8f;
		--primary-blue: #2596be;
		--accent-pink: #e938b0;
		--accent-orange: #f99b0f;
		--accent-yellow: #fdf715;
		--accent-green: #73fd3d;
		--accent-purple: #8E44AD;
		
		--nav-footer-bg: #FFFFFF;
		--nav-footer-text: #2C3E50;
	}

	html {
		font-family: 'Inter', sans-serif;
		background: var(--bg-color);
		color: var(--text-main);
	}

    body {
        margin: 0;
        padding: 0;
    }

    h1, h2, h3, h4, h5, h6 {
        font-family: 'Quicksand', sans-serif;
    }

    .app-container {
        display: flex;
        flex-direction: column;
        min-height: 100vh; /* Permite que el footer baje naturalmente */
    }

    main {
        flex: 1;
        width: 100%;
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem 1rem;
    }

    main.no-padding {
        padding: 0;
        max-width: 100%;
    }

	/* Estilos globales para Navbar y Footer */
	.global-nav-footer {
		background-color: var(--nav-footer-bg);
		color: var(--nav-footer-text);
		border: none;
	}

	.global-nav-footer a, 
	.global-nav-footer button {
		color: var(--nav-footer-text);
	}
</style>