---
import Navbar from '../components/ui/Navbar.astro';
import Footer from '../components/ui/Footer.astro';

interface Props {
	title: string;
	showNavAndFooter?: boolean;
}

const { title, showNavAndFooter = true } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Kuantum - Simulador de Circuitos Cuánticos" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
        
        <!-- Google Fonts -->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Quicksand:wght@500;700&display=swap" rel="stylesheet">
		
        <title>{title}</title>

        <!-- Theme Toggle Script to prevent flashing -->
        <script is:inline>
            const theme = (() => {
                if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
                    return localStorage.getItem('theme');
                }
                if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
                    return 'dark';
                }
                return 'light';
            })();
            if (theme === 'dark') {
                document.documentElement.classList.add('dark');
            }
            window.localStorage.setItem('theme', theme);
        </script>
	</head>
	<body>
        <div class="app-container">
            {showNavAndFooter && <Navbar />}
            <main class={!showNavAndFooter ? "no-padding" : ""}>
                <slot />
            </main>
            {showNavAndFooter && <Footer />}
        </div>
	</body>
</html>

<style is:global>
	:root {
		--bg-color: #F4F7F6;
		--text-main: #2C3E50;
		--primary-blue: #007BFF;
		--secondary-cyan: #00E5FF;
		--koala-grey: #95A5A6;
		--accent-purple: #8E44AD;
		--nav-footer-bg: var(--primary-blue);
		--nav-footer-text: #FFFFFF;
	}

	:root.dark {
		--bg-color: #1A1A1D;
		--text-main: #ECF0F1;
		--primary-blue: #4DABFF;
		--secondary-cyan: #00FFFF;
		--koala-grey: #BDC3C7;
		--accent-purple: #BF5FFF;
		--nav-footer-bg: var(--primary-blue);
		--nav-footer-text: #1A1A1D; /* Oscuro para contraste con el azul claro en dark mode */
	}

	html {
		font-family: 'Inter', sans-serif;
		background: var(--bg-color);
        color: var(--text-main);
        transition: background-color 0.3s ease, color 0.3s ease;
	}

    body {
        margin: 0;
        padding: 0;
    }

    h1, h2, h3, h4, h5, h6 {
        font-family: 'Quicksand', sans-serif;
    }

    .app-container {
        display: flex;
        flex-direction: column;
        min-height: 100vh; /* Permite que el footer baje naturalmente */
    }

    main {
        flex: 1;
        width: 100%;
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem 1rem;
    }

    main.no-padding {
        padding: 0;
        max-width: 100%;
    }

	/* Estilos globales para Navbar y Footer */
	.global-nav-footer {
		background-color: var(--nav-footer-bg);
		color: var(--nav-footer-text);
		border: none;
	}

	.global-nav-footer a, 
	.global-nav-footer button {
		color: var(--nav-footer-text);
	}
</style>